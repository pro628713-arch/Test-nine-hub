-- ====================== Helper Function ======================
local function ExecuteOnTarget(commandName, func, ...)
    if not selectedTarget then
        Rayfield:Notify({
            Title = "خطأ",
            Content = "❌ الرجاء كتابة اسم الهدف والضغط على 'تأكيد الهدف' أولاً",
            Duration = 3,
        })
        return false
    end
    
    -- التأكد من أن اللاعب لا يزال موجوداً
    if not Players:FindFirstChild(selectedTarget.Name) then
        selectedTarget = nil
        if targetDisplayLabel then
            targetDisplayLabel:SetContent("لم يتم اختيار هدف")
        end
        Rayfield:Notify({
            Title = "خطأ",
            Content = "❌ اللاعب غادر السيرفر، الرجاء اختيار هدف جديد",
            Duration = 3,
        })
        return false
    end
    
    local success, err = pcall(func, selectedTarget, ...)
    if not success then
        Rayfield:Notify({
            Title = "خطأ في التنفيذ",
            Content = commandName .. ": " .. tostring(err),
            Duration = 3,
        })
        return false
    end
    
    Rayfield:Notify({
        Title = "✅ تم التنفيذ",
        Content = commandName .. " على " .. selectedTarget.Name,
        Duration = 2,
    })
    return true
end

