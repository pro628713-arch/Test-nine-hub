local function refreshPlayerList()
    for _, child in pairs(plScroll:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= lp then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1, 0, 0, 35)
            btn.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
            btn.BackgroundTransparency = 0.2
            btn.Text = p.Name
            btn.TextColor3 = Color3.fromRGB(220, 220, 220)
            btn.TextSize = 13
            btn.Font = Enum.Font.Gotham
            btn.Parent = plScroll
            local btnCorner = Instance.new("UICorner")
            btnCorner.CornerRadius = UDim.new(0, 6)
            btnCorner.Parent = btn
            btn.MouseButton1Click:Connect(function()
                selectedPlayer = p
                selectedLabel.Text = "✅ " .. p.Name
                for _, child in pairs(plScroll:GetChildren()) do
                    if child:IsA("TextButton") then
                        child.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
                    end
                end
                btn.BackgroundColor3 = Color3.fromRGB(100, 70, 150)
            end)
        end
    end
    plScroll.CanvasSize = UDim2.new(0, 0, 0, plLayout.AbsoluteContentSize.Y)
end

refreshPlayerList()
Players.PlayerAdded:Connect(refreshPlayerList)
Players.PlayerRemoving:Connect(refreshPlayerList)

playerListFrame:GetPropertyChangedSignal("Size"):Connect(function()
