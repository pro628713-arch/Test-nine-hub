RunService.Heartbeat:Connect(function()
    if _G.AntiVoidActive and lp.Character then
        local hrp = lp.Character:FindFirstChild("HumanoidRootPart")
        if hrp and hrp.Position.Y < -350 then hrp.CFrame = CFrame.new(hrp.Position.X, 50, hrp.Position.Z) hrp.Velocity = Vector3.zero end
    end
end)

RunService.Stepped:Connect(function()
    local char = lp.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if spinEnabled and hrp then hrp.CFrame = hrp.CFrame * CFrame.Angles(0, math.rad(spinSpeed * 0.3), 0) hrp.Velocity = Vector3.new(0, hrp.Velocity.Y, 0) end
    if antiFlingAll then for _, p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then p.CanCollide = false end end end
    local isB = (bangEnabled or faceSitEnabled or combinedEnabled or TargetBangV2Enabled or FaceBangV2Enabled)
    if isB then for _, p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end hrp.Velocity = Vector3.zero hrp.RotVelocity = Vector3.zero end
    if not bangTarget or not bangTarget.Character then return end
    local tc = bangTarget.Character
    local thrp = tc:FindFirstChild("HumanoidRootPart")
    local th = tc:FindFirstChild("Head")
    if not thrp or not th then return end
    if holdSixTools then EquipSix() end
    local w = math.sin(tick() * 55) local dr, nr = w * 4.5, w * 2.5
    if combinedEnabled then
        if math.floor(tick() * 60) % 2 == 0 then hrp.CFrame = th.CFrame * CFrame.new(0, -0.6, dr) * CFrame.Angles(0, math.rad(180), 0)
        else hrp.CFrame = thrp.CFrame * CFrame.new(0, 0.5, dr + 1.5) end
    elseif faceSitEnabled then hrp.CFrame = th.CFrame * CFrame.new(0, -0.6, dr) * CFrame.Angles(0, math.rad(180), 0)
    elseif bangEnabled then hrp.CFrame = thrp.CFrame * CFrame.new(0, 0.5, nr + 1.2)
    elseif TargetBangV2Enabled then
        local pts = {}
        for _, p in ipairs(tc:GetChildren()) do if p:IsA("BasePart") then table.insert(pts, p) end end
        if #pts > 0 then hrp.CFrame = pts[math.random(1, #pts)].CFrame * CFrame.new(math.random(-1, 1), math.random(-1, 1), math.random(-1, 1)) * CFrame.Angles(math.rad(math.random(360)), math.rad(math.random(360)), math.rad(math.random(360))) end
    elseif FaceBangV2Enabled then hrp.CFrame = th.CFrame * CFrame.Angles(math.rad(math.random(360)), math.rad(math.random(360)), math.rad(math.random(360)))
    end
    if antiSitEnabled and not isB then local hum = char:FindFirstChildOfClass("Humanoid") if hum then hum.Sit = false hum:SetStateEnabled(Enum.HumanoidStateType.Seated, false) end end
end)

