local function playMusic(id, t)
    pcall(function()
        local v = ReplicatedStorage:WaitForChild("RE", 2):FindFirstChild("1NoMoto1rVehicle1s")
        if v then v:FireServer(t or "SkateBoard") task.wait(0.4) v:FireServer("PickingScooterMusicText", tostring(id)) end
    end)
end

local function GetPlayerMatch(text)
    local st = text:lower()
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= lp and (p.Name:lower():find(st, 1, true) or p.DisplayName:lower():find(st, 1, true)) then return p end
    end
end

local function EquipSix()
    if not lp.Character then return end
    local c = 0
    for _, t in ipairs(lp.Backpack:GetChildren()) do if t:IsA("Tool") and c < 6 then t.Parent = lp.Character c = c + 1 end end
end

local function copyAvatar(tp)
    if not tp or not tp.Character then return end
    local lH = lp.Character:FindFirstChildOfClass("Humanoid")
    local tH = tp.Character:FindFirstChildOfClass("Humanoid")
    if not lH or not tH then return end
    task.spawn(function()
        pcall(function()
            local lD = lH:GetAppliedDescription()
            for _, a in ipairs(lD:GetAccessories(true)) do Remotes.Wear:InvokeServer(tonumber(a.AssetId)) task.wait(0.1) end
            Remotes.Wear:InvokeServer(0) task.wait(0.5)
            local pD = tH:GetAppliedDescription()
            Remotes.ChangeCharacterBody:InvokeServer(unpack({[1] = {pD.Torso, pD.RightArm, pD.LeftArm, pD.RightLeg, pD.LeftLeg, pD.Head}}))
            if pD.Shirt ~= 0 then Remotes.Wear:InvokeServer(tonumber(pD.Shirt)) task.wait(0.2) end
            if pD.Pants ~= 0 then Remotes.Wear:InvokeServer(tonumber(pD.Pants)) task.wait(0.2) end
            for _, a in ipairs(pD:GetAccessories(true)) do if a.AssetId ~= 0 then Remotes.Wear:InvokeServer(tonumber(a.AssetId)) task.wait(0.2) end end
        end)
    end)
end

