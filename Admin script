-- ================== دوال الأوامر ==================
local function getTarget(name)
    if name == "" then return nil end
    return Players:FindFirstChild(name)
end

local function killPlayer(target)
    if target and target.Character then
        local hum = target.Character:FindFirstChildOfClass("Humanoid")
        if hum then hum.Health = 0 end
    end
end

local function bringPlayer(target)
    if target and target.Character then
        local myChar = lp.Character
        if myChar then
            local myHrp = myChar:FindFirstChild("HumanoidRootPart")
            local tHrp = target.Character:FindFirstChild("HumanoidRootPart")
            if myHrp and tHrp then
                tHrp.CFrame = myHrp.CFrame + myHrp.CFrame.LookVector * 3
                tHrp.AssemblyLinearVelocity = Vector3.zero
            end
        end
    end
end

local function tpToPlayer(target)
    if target and target.Character then
        local myChar = lp.Character
        if myChar then
            local myHrp = myChar:FindFirstChild("HumanoidRootPart")
            local tHrp = target.Character:FindFirstChild("HumanoidRootPart")
            if myHrp and tHrp then
                myHrp.CFrame = tHrp.CFrame + tHrp.CFrame.LookVector * -2
                myHrp.AssemblyLinearVelocity = Vector3.zero
            end
        end
    end
end

local function freezePlayer(target)
    if target and target.Character then
        local hrp = target.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            hrp.AssemblyLinearVelocity = Vector3.zero
            local bv = Instance.new("BodyVelocity")
            bv.MaxForce = Vector3.new(1e6,1e6,1e6)
            bv.Velocity = Vector3.zero
            bv.Parent = hrp
            task.delay(1, function() if bv.Parent then bv:Destroy() end end)
        end
    end
end

local function jailPlayer(target)
    if target and target.Character then
        local hrp = target.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local jailPos = CFrame.new(0, 100, 0)
            hrp.CFrame = jailPos
            -- عمل قفص حوله
            local cage = Instance.new("Part")
            cage.Size = Vector3.new(6,6,6)
            cage.Position = jailPos.Position
            cage.Anchored = true
            cage.CanCollide = true
            cage.Transparency = 0.5
            cage.BrickColor = BrickColor.new("Really red")
            cage.Parent = workspace
            task.delay(8, function() cage:Destroy() end)
        end
    end
end

local function rocketPlayer(target)
    if target and target.Character then
        local hrp = target.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local bv = Instance.new("BodyVelocity")
            bv.MaxForce = Vector3.new(1e6,1e6,1e6)
            bv.Velocity = Vector3.new(0, 200, 0) + hrp.CFrame.LookVector * 100
            bv.Parent = hrp
            task.delay(2, function() bv:Destroy() end)
        end
    end
end

local function slapPlayer(target)
    if target and target.Character then
        local hrp = target.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local bv = Instance.new("BodyVelocity")
            bv.MaxForce = Vector3.new(1e6,1e6,1e6)
            bv.Velocity = Vector3.new(math.random(-100,100), 50, math.random(-100,100))
            bv.Parent = hrp
            task.delay(0.5, function() bv:Destroy() end)
        end
    end
end

local function firePlayer(target)
    if target and target.Character then
        local hrp = target.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local fire = Instance.new("Fire")
            fire.Size = 4
            fire.Heat = 10
            fire.Parent = hrp
            task.delay(5, function() fire:Destroy() end)
        end
    end
end

local function loopPlayer(target)
    if target and target.Character then
        local hrp = target.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then
                conn:Disconnect()
                return
            end
            hrp.CFrame = CFrame.new(lp.Character.HumanoidRootPart.Position + Vector3.new(0, 5, 0))
            hrp.AssemblyLinearVelocity = Vector3.zero
        end)
        task.delay(10, function() if conn then conn:Disconnect() end end)
    end
end

-- Jumpscare (على اللاعب المستهدف)
local function jumpscarePlayer(target)
    if not target or not target.Character then return end
    -- إخفاء كاميرا الهدف مؤقتاً وعرض صورة مرعبة
    local playerGui = target:FindFirstChild("PlayerGui")
    if not playerGui then return end
    local jumpscareGui = Instance.new("ScreenGui")
    jumpscareGui.Name = "Jumpscare"
    jumpscareGui.IgnoreGuiInset = true
    jumpscareGui.Parent = playerGui
    
    local image = Instance.new("ImageLabel")
    image.Size = UDim2.new(1,0,1,0)
    image.Image = "rbxassetid://1234567890" -- ضع ID صورة مرعبة (مؤقت)
    image.BackgroundColor3 = Color3.new(1,1,1)
    image.BackgroundTransparency = 0
    image.Parent = jumpscareGui
    
    -- صوت مخيف
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://138184443" -- صوت صراخ (جرب تغيره)
    sound.Volume = 1
    sound.Parent = jumpscareGui
    sound:Play()
    
    -- اهتزاز الشاشة لهدف
    local originalCFrame = workspace.CurrentCamera.CFrame
    local start = tick()
    while tick() - start < 0.5 do
        workspace.CurrentCamera.CFrame = originalCFrame * CFrame.new(math.random(-1,1)/10, math.random(-1,1)/10, 0)
        RunService.RenderStepped:Wait()
    end
    workspace.CurrentCamera.CFrame = originalCFrame
    
    task.delay(2, function() jumpscareGui:Destroy() end)
end

