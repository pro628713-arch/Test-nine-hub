    PlaceholderText = "Enter target name...",
    Callback = function(text)
        targetName = text
    end
})

-- دالة للحصول على اللاعب من الاسم المدخل
local function getCurrentTarget()
    if targetName == "" then
        Rayfield:Notify({Title = "Error", Content = "Please enter a player name", Duration = 2})
        return nil
    end
    local target = Players:FindFirstChild(targetName)
    if not target then
        Rayfield:Notify({Title = "Error", Content = "Player not found", Duration = 2})
        return nil
    end
    return target
end

